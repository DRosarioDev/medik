spring.application.name=medik
spring.profiles.active=hibernate

spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.deserialization.fail-on-unknown-properties=false
spring.jackson.time-zone=Europe/Rome

# Da attivare quando si vuole escludere l'autoconfigurazione di Spring Boot per JPA e DataSource, 
# ad esempio per utilizzare un database in-memory o una configurazione personalizzata
# spring.autoconfigure.exclude=\
#   org.springframework.boot.autoconfigure.orm.jpa.HibernateJpaAutoConfiguration,\
#   org.springframework.boot.autoconfigure.jdbc.DataSourceAutoConfiguration,\
#   org.springframework.boot.autoconfigure.jdbc.DataSourceTransactionManagerAutoConfiguration

# Datasource PostgreSQL
spring.datasource.url=jdbc:postgresql:nome_del_tuo_database
spring.datasource.username=username
spring.datasource.password=password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA/Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true